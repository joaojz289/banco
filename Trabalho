// ================= ADICIONAR =================

void adicionar(char arquivo[], int tipo) {

    Registro r;

    if (total == 0)
        r.id = 1;
    else
        r.id = registros[total - 1].id + 1;

    getchar();

    printf("\nNome: ");
    fgets(r.nome, 50, stdin);
    r.nome[strcspn(r.nome, "\n")] = 0;

    printf("CPF: ");
    fgets(r.cpf, 20, stdin);
    r.cpf[strcspn(r.cpf, "\n")] = 0;

    strcpy(r.matricula, "-");
    strcpy(r.turma, "-");

    strcpy(r.convenio, "-");
    strcpy(r.tipoSanguineo, "-");

    strcpy(r.cargo, "-");
    strcpy(r.setor, "-");

    strcpy(r.consulta, "-");
    strcpy(r.medico, "-");

    // ESCOLA
    if (tipo == 1) {

        printf("Matricula: ");
        fgets(r.matricula, 20, stdin);
        r.matricula[strcspn(r.matricula, "\n")] = 0;

        printf("Turma: ");
        fgets(r.turma, 20, stdin);
        r.turma[strcspn(r.turma, "\n")] = 0;
    }

    // HOSPITAL
    else if (tipo == 2) {

        printf("Convenio: ");
        fgets(r.convenio, 30, stdin);
        r.convenio[strcspn(r.convenio, "\n")] = 0;

        printf("Tipo sanguineo: ");
        fgets(r.tipoSanguineo, 10, stdin);
        r.tipoSanguineo[strcspn(r.tipoSanguineo, "\n")] = 0;
    }

    // EMPRESA
    else if (tipo == 3) {

        printf("Cargo: ");
        fgets(r.cargo, 30, stdin);
        r.cargo[strcspn(r.cargo, "\n")] = 0;

        printf("Setor: ");
        fgets(r.setor, 30, stdin);
        r.setor[strcspn(r.setor, "\n")] = 0;
    }

    // CLINICA
    else if (tipo == 4) {

        printf("Consulta: ");
        fgets(r.consulta, 30, stdin);
        r.consulta[strcspn(r.consulta, "\n")] = 0;

        printf("Medico: ");
        fgets(r.medico, 30, stdin);
        r.medico[strcspn(r.medico, "\n")] = 0;
    }

    registros[total] = r;

    total++;

    salvar(arquivo);

    printf("\nRegistro salvo com ID %d!\n", r.id);
}

// ================= LISTAR =================

void listar(int tipo) {

    printf("\n===== REGISTROS =====\n");

    for (int i = 0; i < total; i++) {

        printf("\nID: %d\n", registros[i].id);
        printf("Nome: %s\n", registros[i].nome);
        printf("CPF: %s\n", registros[i].cpf);

        if (tipo == 1) {

            printf("Matricula: %s\n", registros[i].matricula);
            printf("Turma: %s\n", registros[i].turma);
        }

        else if (tipo == 2) {

            printf("Convenio: %s\n", registros[i].convenio);
            printf("Tipo sanguineo: %s\n", registros[i].tipoSanguineo);
        }

        else if (tipo == 3) {

            printf("Cargo: %s\n", registros[i].cargo);
            printf("Setor: %s\n", registros[i].setor);
        }

        else if (tipo == 4) {

            printf("Consulta: %s\n", registros[i].consulta);
            printf("Medico: %s\n", registros[i].medico);
        }
    }
}

// ================= APAGAR =================

void apagar(char arquivo[]) {

    int id;
    int achou = 0;

    printf("\nDigite o ID: ");
    scanf("%d", &id);

    for (int i = 0; i < total; i++) {

        if (registros[i].id == id) {

            achou = 1;

            for (int j = i; j < total - 1; j++) {

                registros[j] = registros[j + 1];
            }

            total--;

            salvar(arquivo);

            printf("\nRegistro apagado!\n");

            break;
        }
    }

    if (!achou)
        printf("\nID nao encontrado!\n");
}

// ================= MENU =================

void menuBanco(char arquivo[], int tipo) {

    int op;

    criarDadosIniciais(arquivo, tipo);

    carregar(arquivo);

    do {

        printf("\n===== MENU =====\n");
        printf("1 - Adicionar\n");
        printf("2 - Listar\n");
        printf("3 - Apagar\n");
        printf("4 - Voltar\n");
        printf("Escolha: ");

        scanf("%d", &op);

        switch(op) {

            case 1:
                adicionar(arquivo, tipo);
                break;

            case 2:
                listar(tipo);
                break;

            case 3:
                apagar(arquivo);
                break;
        }

    } while(op != 4);
}

