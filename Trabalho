#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX 300

// ================= STRUCT =================

typedef struct {
    int id;
    char nome[50];
    char cpf[20];

    // ESCOLA
    char matricula[20];
    char turma[20];

    // HOSPITAL
    char convenio[30];
    char tipoSanguineo[10];

    // EMPRESA
    char cargo[30];
    char setor[30];

    // CLINICA
    char consulta[30];
    char medico[30];

} Registro;

// ================= VARIÁVEIS =================

Registro registros[MAX];
int total = 0;

// ================= SALVAR =================

void salvar(char arquivo[]) {

    FILE *f = fopen(arquivo, "w");

    if (f == NULL) {
        printf("\nErro ao salvar arquivo!\n");
        return;
    }

    for (int i = 0; i < total; i++) {

        fprintf(f,
        "%d|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s\n",

        registros[i].id,
        registros[i].nome,
        registros[i].cpf,

        registros[i].matricula,
        registros[i].turma,

        registros[i].convenio,
        registros[i].tipoSanguineo,

        registros[i].cargo,
        registros[i].setor,

        registros[i].consulta,
        registros[i].medico
        );
    }

    fclose(f);
}

// ================= CARREGAR =================

void carregar(char arquivo[]) {

    FILE *f = fopen(arquivo, "r");

    total = 0;

    if (f == NULL)
        return;

    while (
        fscanf(f,
        "%d|%49[^|]|%19[^|]|%19[^|]|%19[^|]|%29[^|]|%9[^|]|%29[^|]|%29[^|]|%29[^|]|%29[^\n]\n",

        &registros[total].id,
        registros[total].nome,
        registros[total].cpf,

        registros[total].matricula,
        registros[total].turma,

        registros[total].convenio,
        registros[total].tipoSanguineo,

        registros[total].cargo,
        registros[total].setor,

        registros[total].consulta,
        registros[total].medico

        ) != EOF
    ) {

        total++;
    }

    fclose(f);
}

