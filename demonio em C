/*
 * Exibe todas as informações de um único registro em formato vertical
 * (ficha completa). Usa rótulos específicos da categoria.
 */
void exibir_registro_completo(const BancoDados *bd, const Registro *r) {
    linha('-', 62);
    printf("  " C_BOLD C_CIANO "ID:           " C_RESET C_VERDE "#%04d\n" C_RESET, r->id);
    printf("  " C_BOLD         "Nome:         " C_RESET "%s\n",   r->nome);
    printf("  " C_BOLD         "CPF:          " C_RESET "%s\n",   r->cpf);
    printf("  " C_BOLD         "Telefone:     " C_RESET "%s\n",   r->telefone);
    printf("  " C_BOLD         "Email:        " C_RESET "%s\n",   r->email);
    printf("  " C_BOLD "%-14s" C_RESET "%s\n",   bd->label1, r->campo1);
    printf("  " C_BOLD "%-14s" C_RESET "%s\n",   bd->label2, r->campo2);
    printf("  " C_BOLD "%-14s" C_RESET "%s\n",   bd->label3, r->campo3);
    printf("  " C_BOLD         "Cadastro:     " C_RESET "%s\n",   r->data_cadastro);
    if (strlen(r->observacoes) > 0)
        printf("  " C_BOLD     "Observacoes:  " C_RESET "%s\n",   r->observacoes);
    linha('-', 62);
}

/* Imprime o cabeçalho da tabela resumida com os rótulos da categoria */
