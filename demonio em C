int carregar_banco(BancoDados *bd) {
    FILE *f = fopen(bd->arquivo, "r");
    if (!f) return 0; /* arquivo ainda não criado — primeira vez */

    char linha_buf[TAM_LINHA];

    /* Pula a linha de cabeçalho */
    if (!fgets(linha_buf, sizeof(linha_buf), f)) {
        fclose(f); return 0;
    }

    bd->total      = 0;
    bd->proximo_id = 1;

    while (fgets(linha_buf, sizeof(linha_buf), f) && bd->total < MAX_REGISTROS) {
        linha_buf[strcspn(linha_buf, "\n\r")] = '\0';
        if (strlen(linha_buf) < 3) continue; /* linha vazia */

        Registro *r   = &bd->registros[bd->total];
        char copia[TAM_LINHA];
        strncpy(copia, linha_buf, TAM_LINHA - 1);

        /* Desempacota cada campo usando strtok com delimitador '|' */
        char *tok;
        tok = strtok(copia, "|");  if (!tok) continue;
        r->id = atoi(tok);

        tok = strtok(NULL, "|"); if (tok) strncpy(r->nome,          tok, TAM_NOME  - 1);
        tok = strtok(NULL, "|"); if (tok) strncpy(r->cpf,           tok, TAM_CPF   - 1);
        tok = strtok(NULL, "|"); if (tok) strncpy(r->telefone,      tok, TAM_TEL   - 1);
        tok = strtok(NULL, "|"); if (tok) strncpy(r->email,         tok, TAM_EMAIL - 1);
        tok = strtok(NULL, "|"); if (tok) strncpy(r->campo1,        tok, TAM_CAMPO - 1);
        tok = strtok(NULL, "|"); if (tok) strncpy(r->campo2,        tok, TAM_CAMPO - 1);
        tok = strtok(NULL, "|"); if (tok) strncpy(r->campo3,        tok, TAM_CAMPO - 1);
        tok = strtok(NULL, "|"); if (tok) strncpy(r->data_cadastro, tok, TAM_DATA  - 1);
        tok = strtok(NULL, "|"); if (tok) strncpy(r->observacoes,   tok, TAM_OBS   - 1);

        /* Garante que o próximo ID seja sempre maior que qualquer ID existente */
        if (r->id >= bd->proximo_id)
            bd->proximo_id = r->id + 1;

        bd->total++;
    }

    fclose(f);
    return 1;
}

/*
 * Grava todos os registros da memória no arquivo CSV correspondente.
 * Chamado automaticamente após qualquer operação de escrita (add/edit/delete).
 *
 * Retorna 1 em sucesso, 0 em falha de I/O.
 */
int salvar_banco(BancoDados *bd) {
    FILE *f = fopen(bd->arquivo, "w");
    if (!f) {
        printf(C_VERM "\n  [ERRO] Falha ao salvar: %s\n" C_RESET, bd->arquivo);
        return 0;
    }

    /* Linha de cabeçalho (facilita leitura manual do CSV) */
    fprintf(f, "id|nome|cpf|telefone|email|campo1|campo2|campo3|data_cadastro|observacoes\n");

    /* Grava cada registro como uma linha */
    for (int i = 0; i < bd->total; i++) {
        const Registro *r = &bd->registros[i];
        fprintf(f, "%d|%s|%s|%s|%s|%s|%s|%s|%s|%s\n",
            r->id,
            r->nome,
            r->cpf,
            r->telefone,
            r->email,
            r->campo1,
            r->campo2,
            r->campo3,
            r->data_cadastro,
            r->observacoes);
    }

    fclose(f);
    return 1;
}

