}

void pausar(void) {
    printf(COR_AMAR "\n  Pressione ENTER para continuar..." COR_RESET);
    int c;
    while ((c = getchar()) != '\n' && c != EOF);
}

void linha(char c, int tam) {
    printf("  ");
    for (int i = 0; i < tam; i++) putchar(c);
    putchar('\n');
}

void cabecalho(const char *titulo) {
    limpar_tela();
    printf("\n");
    linha('=', 50);
    printf("  " COR_NEGRITO COR_CIANO "MeuBanco — %s" COR_RESET "\n", titulo);
    linha('=', 50);
    printf("\n");
} 

