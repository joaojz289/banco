/* Imprime uma linha na tabela resumida */
void exibir_linha_tabela(const Registro *r) {
    printf("  " C_VERDE "#%-4d" C_RESET " %-30s %-15s %-15s %-14s\n",
           r->id, r->nome, r->campo1, r->campo2, r->cpf);
}

/* ================================================================
   SEÇÃO 11 — BUSCA
   ================================================================ */

/*
 * Localiza um registro pelo ID usando busca linear.
 * Retorna ponteiro para o registro, ou NULL se não encontrado.
 *
 * Para bancos com até 5000 registros, a busca linear é rápida
 * (< 1 ms). Para volumes maiores, seria substituída por busca binária
 * após ordenação por ID, ou por hash table.
 */
Registro *buscar_por_id(BancoDados *bd, int id) {
    for (int i = 0; i < bd->total; i++)
        if (bd->registros[i].id == id)
            return &bd->registros[i];
    return NULL;
}

/*
 * Busca registros cujo nome contenha a string digitada (parcial).
 * A comparação é case-insensitive: "ana" encontra "Ana Paula" e "JOANA".
 *
 * Algoritmo:
 *   1. Converte a query para minúsculas (str_para_lower)
 *   2. Para cada registro, converte o nome para minúsculas
 *   3. Usa strstr() para verificar se a query está contida no nome
 *   4. Coleta ponteiros para os registros que combinam
 *   5. Exibe resultado simples (1 resultado) ou tabela (vários)
 *
 * Complexidade: O(n) — percorre todos os registros uma vez.
 */
void buscar_por_nome(BancoDados *bd) {
    cabecalho("Buscar por Nome");
    printf("  Categoria: " C_AMAR "%s" C_RESET
           "  |  Registros: " C_VERDE "%d" C_RESET "\n\n", bd->nome, bd->total);

    if (bd->total == 0) {
        printf("  " C_AMAR "Nenhum registro cadastrado nesta categoria.\n" C_RESET);
        pausar(); return;
    }

    char query[TAM_NOME], query_low[TAM_NOME];
    ler_campo("Parte do nome (busca parcial): ", query, TAM_NOME);
    if (strlen(query) == 0) { pausar(); return; }
    str_para_lower(query_low, query);

    /* Coleta ponteiros para os registros correspondentes */
    Registro *res[MAX_REGISTROS];
    int total_res = 0;

    for (int i = 0; i < bd->total; i++) {
        char nome_low[TAM_NOME];
        str_para_lower(nome_low, bd->registros[i].nome);
        if (strstr(nome_low, query_low))
            res[total_res++] = &bd->registros[i];
    }

    printf("\n");

    if (total_res == 0) {
        printf("  " C_VERM "Nenhum resultado para \"%s\".\n" C_RESET, query);
        pausar(); return;
    }

    printf("  " C_VERDE "%d resultado(s) encontrado(s) para \"%s\":\n\n" C_RESET,
           total_res, query);

    if (total_res == 1) {
        /* Único resultado: exibe ficha completa diretamente */
        exibir_registro_completo(bd, res[0]);
    } else {
        /* Vários resultados: exibe tabela resumida */
        exibir_cabecalho_tabela(bd);
        for (int i = 0; i < total_res; i++)
            exibir_linha_tabela(res[i]);
        linha('-', 82);

        /* Permite ver a ficha completa de qualquer resultado */
        printf("\n  Ver ficha completa de um registro (ID ou 0 para voltar): ");
        int id_det;
        if (scanf("%d", &id_det) == 1 && id_det > 0) {
            getchar();
            for (int i = 0; i < total_res; i++) {
                if (res[i]->id == id_det) {
                    printf("\n");
                    exibir_registro_completo(bd, res[i]);
                    break;
                }
            }
        } else {
            getchar();
        }
    }

    pausar();
}

/* ================================================================
   SEÇÃO 12 — CRUD: ADICIONAR
   ================================================================ */

/*
 * Adiciona um novo registro ao banco de dados.
 *
 * Passos:
 *   1. Valida se o limite não foi atingido
 *   2. Coleta todos os campos com validação
 *   3. Verifica duplicidade de CPF
 *   4. Exibe prévia e solicita confirmação
 *   5. Insere na memória, incrementa ID e salva no disco
 */
void adicionar_registro(BancoDados *bd) {
    cabecalho("Adicionar Registro");
    printf("  Categoria: " C_AMAR "%s" C_RESET "\n\n", bd->nome);

    if (bd->total >= MAX_REGISTROS) {
        printf("  " C_VERM "Limite de %d registros atingido.\n" C_RESET, MAX_REGISTROS);
        pausar(); return;
    }

    Registro novo;
    memset(&novo, 0, sizeof(Registro));
    novo.id = bd->proximo_id;

    /* --- Nome: mínimo 3 caracteres --- */
    do {
        ler_campo("Nome completo:  ", novo.nome, TAM_NOME);
        if (strlen(novo.nome) < 3)
            printf("  " C_VERM "Nome muito curto. Minimo 3 caracteres.\n" C_RESET);
    } while (strlen(novo.nome) < 3);

    /* --- CPF: formato e unicidade --- */
    do {
        ler_campo("CPF (11 digitos): ", novo.cpf, TAM_CPF);
        if (!cpf_valido(novo.cpf)) {
            printf("  " C_VERM "CPF invalido. Use 11 digitos numericos.\n" C_RESET);
            memset(novo.cpf, 0, TAM_CPF);
            continue;
        }
        formatar_cpf(novo.cpf);
        if (cpf_duplicado(bd, novo.cpf)) {
            printf("  " C_VERM "CPF ja cadastrado nesta categoria!\n" C_RESET);
            memset(novo.cpf, 0, TAM_CPF);
        }
    } while (strlen(novo.cpf) == 0);

    /* --- Campos básicos --- */
    ler_campo("Telefone:       ", novo.telefone, TAM_TEL);
    ler_campo("Email:          ", novo.email,    TAM_EMAIL);

    /* --- Campos específicos da categoria --- */
    printf("\n  " C_CIANO "--- Campos especificos: %s ---\n\n" C_RESET, bd->nome);

    char prompt[40];
    snprintf(prompt, sizeof(prompt), "%-16s: ", bd->label1);
    ler_campo(prompt, novo.campo1, TAM_CAMPO);
    snprintf(prompt, sizeof(prompt), "%-16s: ", bd->label2);
    ler_campo(prompt, novo.campo2, TAM_CAMPO);
    snprintf(prompt, sizeof(prompt), "%-16s: ", bd->label3);
    ler_campo(prompt, novo.campo3, TAM_CAMPO);

    printf("\n");
    ler_campo("Observacoes (opcional): ", novo.observacoes, TAM_OBS);

    /* Timestamp automático */
    obter_data(novo.data_cadastro, TAM_DATA);

    /* --- Prévia e confirmação --- */
    printf("\n  " C_BOLD "--- PREVIEW DO REGISTRO ---\n" C_RESET);
    exibir_registro_completo(bd, &novo);

    printf("\n  Confirmar cadastro? (s/n): ");
    char conf[4];
    if (!fgets(conf, sizeof(conf), stdin) || tolower((unsigned char)conf[0]) != 's') {
        printf("  " C_AMAR "Cadastro cancelado.\n" C_RESET);
        pausar(); return;
    }

    /* Insere na memória e salva */
    bd->registros[bd->total++] = novo;
    bd->proximo_id++;
    salvar_banco(bd);

    printf("  " C_VERDE "Registro #%04d adicionado com sucesso!\n" C_RESET, novo.id);
    pausar();
}

/* ================================================================
   SEÇÃO 13 — CRUD: DELETAR
   ================================================================ */

/*
 * Remove um registro do banco de dados.
 * Permite deletar por ID ou por busca de nome.
 * Solicita confirmação antes de efetivar a exclusão.
 *
 * Remoção física: desloca todos os registros seguintes uma posição
 * para trás no array, sobrescrevendo o registro excluído.
 */
void deletar_registro(BancoDados *bd) {
    cabecalho("Deletar Registro");
    printf("  Categoria: " C_AMAR "%s" C_RESET
           "  |  Registros: " C_VERDE "%d" C_RESET "\n\n", bd->nome, bd->total);

    if (bd->total == 0) {
        printf("  " C_AMAR "Nenhum registro para deletar.\n" C_RESET);
        pausar(); return;
    }

    printf("  Buscar por:\n");
    printf("  " C_AZUL "[1]" C_RESET " ID\n");
    printf("  " C_AZUL "[2]" C_RESET " Nome\n");
    printf("  " C_AZUL "[0]" C_RESET " Cancelar\n\n");

    int opcao = ler_inteiro("Opcao: ");
    Registro *alvo = NULL;

    if (opcao == 1) {
        int id = ler_inteiro("ID do registro: ");
        alvo = buscar_por_id(bd, id);

    } else if (opcao == 2) {
        char nome[TAM_NOME], nome_low[TAM_NOME];
        ler_campo("Nome (parcial): ", nome, TAM_NOME);
        str_para_lower(nome_low, nome);

        /* Coleta candidatos */
        Registro *cands[MAX_REGISTROS];
        int qtd = 0;
        for (int i = 0; i < bd->total; i++) {
            char n[TAM_NOME];
            str_para_lower(n, bd->registros[i].nome);
            if (strstr(n, nome_low))
                cands[qtd++] = &bd->registros[i];
        }

        if (qtd == 0) {
            printf("  " C_VERM "Nenhum registro encontrado.\n" C_RESET);
            pausar(); return;
        } else if (qtd == 1) {
            alvo = cands[0];
        } else {
            printf("\n  Multiplos resultados encontrados:\n");
            exibir_cabecalho_tabela(bd);
            for (int i = 0; i < qtd; i++) exibir_linha_tabela(cands[i]);
            linha('-', 82);
            int id = ler_inteiro("\n  ID do registro a deletar: ");
            alvo = buscar_por_id(bd, id);
        }
    } else {
        return; /* cancelado */
    }

    if (!alvo) {
        printf("  " C_VERM "Registro nao encontrado.\n" C_RESET);
        pausar(); return;
    }

    /* Exibe o registro a ser removido */
    printf("\n  Registro selecionado para exclusao:\n");
    exibir_registro_completo(bd, alvo);

    printf("\n  " C_VERM C_BOLD
           "ATENCAO: Esta acao e irreversivel! Confirmar exclusao? (s/n): "
           C_RESET);
    char conf[4];
    if (!fgets(conf, sizeof(conf), stdin) || tolower((unsigned char)conf[0]) != 's') {
        printf("  Exclusao cancelada.\n");
        pausar(); return;
    }

    /* Remove deslocando os registros subsequentes */
    int idx    = (int)(alvo - bd->registros);
    int id_del = alvo->id;
    for (int i = idx; i < bd->total - 1; i++)
        bd->registros[i] = bd->registros[i + 1];
    bd->total--;

    salvar_banco(bd);
    printf("  " C_VERDE "Registro #%04d excluido com sucesso.\n" C_RESET, id_del);
    pausar();
}

/* ================================================================
   SEÇÃO 14 — CRUD: EDITAR
   ================================================================ */

/*
 * Edita campos de um registro existente.
 * O CPF não pode ser alterado para preservar a integridade.
 * Campos deixados em branco mantêm seus valores originais.
 * A edição só é salva após confirmação do usuário.
 */
void editar_registro(BancoDados *bd) {
    cabecalho("Editar Registro");
    printf("  Categoria: " C_AMAR "%s" C_RESET "\n\n", bd->nome);

    if (bd->total == 0) {
        printf("  " C_AMAR "Nenhum registro para editar.\n" C_RESET);
        pausar(); return;
    }

    int id = ler_inteiro("ID do registro a editar: ");
    Registro *r = buscar_por_id(bd, id);

    if (!r) {
        printf("  " C_VERM "Registro #%d nao encontrado.\n" C_RESET, id);
        pausar(); return;
    }

    printf("\n  Registro atual:\n");
    exibir_registro_completo(bd, r);
    printf("\n  " C_AMAR "Deixe em branco para manter o valor atual.\n\n" C_RESET);

    /* Salva backup para caso de cancelamento */
    Registro backup = *r;

    ler_campo_opcional("Nome",        r->nome,       TAM_NOME,  r->nome);
    ler_campo_opcional("Telefone",    r->telefone,   TAM_TEL,   r->telefone);
    ler_campo_opcional("Email",       r->email,      TAM_EMAIL, r->email);

    printf("\n  " C_CIANO "--- Campos especificos ---\n\n" C_RESET);
    ler_campo_opcional(bd->label1,    r->campo1,     TAM_CAMPO, r->campo1);
    ler_campo_opcional(bd->label2,    r->campo2,     TAM_CAMPO, r->campo2);
    ler_campo_opcional(bd->label3,    r->campo3,     TAM_CAMPO, r->campo3);
    ler_campo_opcional("Observacoes", r->observacoes, TAM_OBS,  r->observacoes);

    printf("\n  Confirmar alteracoes? (s/n): ");
    char conf[4];
    if (!fgets(conf, sizeof(conf), stdin) || tolower((unsigned char)conf[0]) != 's') {
        *r = backup; /* restaura o estado original */
        printf("  " C_AMAR "Edicao cancelada.\n" C_RESET);
        pausar(); return;
    }

    salvar_banco(bd);
    printf("  " C_VERDE "Registro #%04d atualizado com sucesso!\n" C_RESET, r->id);
    pausar();
}

/* ================================================================
   SEÇÃO 15 — CRUD: LISTAR
   ================================================================ */

/*
 * Exibe todos os registros de uma categoria em formato de tabela.
 * Permite escolher ordenação por nome ou por ID.
 * Trabalha sobre uma cópia do array para não alterar a ordem original.
 * Oferece opção de ver a ficha completa de qualquer registro.
 */
void listar_registros(BancoDados *bd) {
    cabecalho("Listar Registros");
    printf("  Categoria: " C_AMAR "%s" C_RESET
           "  |  Registros: " C_VERDE "%d" C_RESET "\n\n", bd->nome, bd->total);

    if (bd->total == 0) {
        printf("  " C_AMAR "Nenhum registro cadastrado.\n" C_RESET);
        pausar(); return;
    }

    printf("  Ordenar por:\n");
    printf("  " C_AZUL "[1]" C_RESET " Nome (A-Z)\n");
    printf("  " C_AZUL "[2]" C_RESET " ID (crescente)\n");
    int ord = ler_inteiro("\n  Opcao: ");

    /* Cópia local para ordenação sem afetar os dados originais */
    Registro *copia = malloc(bd->total * sizeof(Registro));
    if (!copia) {
        printf("  " C_VERM "Memoria insuficiente.\n" C_RESET);
        pausar(); return;
    }
    memcpy(copia, bd->registros, bd->total * sizeof(Registro));

    if (ord == 1)
        qsort(copia, bd->total, sizeof(Registro), cmp_nome);
    else
        qsort(copia, bd->total, sizeof(Registro), cmp_id);

    printf("\n");
    exibir_cabecalho_tabela(bd);
    for (int i = 0; i < bd->total; i++)
        exibir_linha_tabela(&copia[i]);
    linha('-', 82);
    printf("  Total: " C_VERDE "%d" C_RESET " registro(s)\n", bd->total);

    /* Ver ficha completa */
    printf("\n  Ver ficha completa (ID ou 0 para voltar): ");
    int id_det;
    if (scanf("%d", &id_det) == 1 && id_det > 0) {
        getchar();
        Registro *r = buscar_por_id(bd, id_det);
        if (r) { printf("\n"); exibir_registro_completo(bd, r); }
        else printf("  " C_VERM "ID nao encontrado.\n" C_RESET);
    } else {
        getchar();
    }

    free(copia);
    pausar();
}

/* ================================================================
   SEÇÃO 16 — SISTEMA DE LOGIN
   ================================================================ */

/*
 * Exibe a tela de login e valida as credenciais do administrador.
 * Limita a 3 tentativas por segurança.
 * Retorna 1 em caso de sucesso, 0 em caso de bloqueio.
 */
int menu_login(void) {
    int tentativas = 3;

    while (tentativas > 0) {
        cabecalho("Login do Administrador");
        printf("  " C_BOLD "SGBDLite v1.0" C_RESET
               " — Sistema de Gerenciamento de Banco de Dados\n");
        printf("  Desenvolvido em Linguagem C\n\n");
        linha('-', 62);
        printf("  " C_AMAR "Tentativas restantes: %d\n\n" C_RESET, tentativas);

        char usuario[TAM_NOME], senha[TAM_SENHA];
        ler_campo("Usuario: ", usuario, TAM_NOME);
        ler_campo("Senha:   ", senha,   TAM_SENHA);

        if (strcmp(usuario, ADMIN_USUARIO) == 0 &&
            strcmp(senha,   ADMIN_SENHA)   == 0) {
            printf("\n  " C_VERDE
                   "Login realizado com sucesso! Bem-vindo, %s.\n" C_RESET, usuario);
            pausar();
            return 1;
        }

        printf("\n  " C_VERM "Usuario ou senha incorretos.\n" C_RESET);
        tentativas--;
        if (tentativas > 0) pausar();
    }

    printf("\n  " C_VERM
           "Numero maximo de tentativas atingido. Encerrando.\n" C_RESET);
    return 0;
}

/* ================================================================
   SEÇÃO 17 — MENUS PRINCIPAIS
   ================================================================ */

/*
 * Menu principal de uma categoria específica.
 * Loop até o usuário escolher sair ou trocar de categoria.
 */
void menu_principal(BancoDados *bd) {
    int op;
    do {
        cabecalho("Menu Principal");
        printf("  Categoria: " C_MGNT C_BOLD "%s %s" C_RESET
               "  |  Registros: " C_VERDE "%d" C_RESET "\n\n",
               bd->icone, bd->nome, bd->total);

        printf("  " C_AZUL "[1]" C_RESET " Buscar por nome\n");
        printf("  " C_AZUL "[2]" C_RESET " Deletar registro\n");
        printf("  " C_AZUL "[3]" C_RESET " Adicionar registro\n");
        printf("  " C_AZUL "[4]" C_RESET " Listar todos os registros\n");
        printf("  " C_AZUL "[5]" C_RESET " Editar registro\n");
        printf("  " C_AZUL "[6]" C_RESET " Trocar categoria\n");
        printf("  " C_AZUL "[0]" C_RESET " Sair do sistema\n");

        op = ler_inteiro("\n  Opcao: ");

        switch (op) {
            case 1: buscar_por_nome(bd);    break;
            case 2: deletar_registro(bd);   break;
            case 3: adicionar_registro(bd); break;
            case 4: listar_registros(bd);   break;
            case 5: editar_registro(bd);    break;
            case 6: return; /* retorna para seleção de categoria */
            case 0: break;
            default:
                printf("  " C_VERM "Opcao invalida.\n" C_RESET);
                pausar();
        }
    } while (op != 0);
}

/*
 * Menu de seleção de categoria.
 * Loop externo que mantém o sistema rodando até o usuário sair.
 */
void menu_categorias(void) {
    int op;
    do {
        cabecalho("Selecionar Categoria");
        printf("  Escolha o banco de dados:\n\n");

        for (int i = 0; i < NUM_CATEGORIAS; i++) {
            printf("  " C_AZUL "[%d]" C_RESET " %s %-12s"
                   C_AMAR " (%d registros)" C_RESET "\n",
                   i + 1, bancos[i].icone, bancos[i].nome, bancos[i].total);
        }
        printf("  " C_AZUL "[0]" C_RESET " Sair do sistema\n");

        op = ler_inteiro("\n  Opcao: ");

        if (op >= 1 && op <= NUM_CATEGORIAS)
            menu_principal(&bancos[op - 1]);
        else if (op != 0) {
            printf("  " C_VERM "Opcao invalida.\n" C_RESET);
            pausar();
        }
    } while (op != 0);
}

/* ================================================================
   SEÇÃO 18 — PONTO DE ENTRADA
   ================================================================ */

int main(void) {
    /* Carrega todos os bancos de dados do disco para a memória */
    inicializar_sistema();

    /* Autenticação obrigatória */
    if (!menu_login())
        return 1;

    /* Loop principal de categorias */
    menu_categorias();

    /* Mensagem de encerramento */
    cabecalho("Encerrando o Sistema");
    printf("  " C_VERDE "Todos os dados foram salvos automaticamente.\n" C_RESET);
    printf("  " C_CIANO "Obrigado por usar o SGBDLite!\n\n" C_RESET);
    linha('=', 62);
    printf("\n");

    return 0;
}

