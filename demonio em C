   ================================================================ */

/*
 * Remove espaços em branco no início e no fim de uma string.
 * Modifica a string in-place.
 */
void trim(char *str) {
    if (!str || !*str) return;

    /* Remove espaços do início */
    char *inicio = str;
    while (isspace((unsigned char)*inicio)) inicio++;
    if (inicio != str)
        memmove(str, inicio, strlen(inicio) + 1);

    /* Remove espaços do final */
    char *fim = str + strlen(str) - 1;
    while (fim > str && isspace((unsigned char)*fim)) fim--;
    *(fim + 1) = '\0';
}

/*
 * Converte 'src' para minúsculas e armazena em 'dest'.
 * Usado na busca case-insensitive.
 */
void str_para_lower(char *dest, const char *src) {
    int i;
    for (i = 0; src[i]; i++)
        dest[i] = (char)tolower((unsigned char)src[i]);
    dest[i] = '\0';
}

/* Obtém data e hora atuais no formato dd/mm/aaaa hh:mm */
void obter_data(char *buf, int tam) {
    time_t t = time(NULL);
    struct tm *tm_info = localtime(&t);
    strftime(buf, tam, "%d/%m/%Y %H:%M", tm_info);
}

/*
 * Lê uma string do teclado com prompt.
 * Limita ao tamanho máximo e remove newline e espaços extras.
 */
void ler_campo(const char *prompt, char *dest, int max) {
    printf("  %s", prompt);
    if (fgets(dest, max, stdin)) {
        dest[strcspn(dest, "\n")] = '\0';
        trim(dest);
    }
}

/*
 * Lê um campo opcional: se o usuário pressionar ENTER sem digitar,
 * mantém o valor atual. Caso contrário, substitui pelo novo.
 */
void ler_campo_opcional(const char *label, char *dest, int max, const char *atual) {
    char buf[TAM_LINHA] = {0};
    printf("  %-14s [" C_AMAR "%s" C_RESET "]: ", label, atual);
    if (fgets(buf, sizeof(buf), stdin)) {
        buf[strcspn(buf, "\n")] = '\0';
        trim(buf);
        if (strlen(buf) > 0)
            strncpy(dest, buf, max - 1);
        /* Se vazio, dest permanece com valor atual */
    }
}

/*
 * Lê um número inteiro do teclado com validação básica.
 * Descarta caracteres extras para não poluir o buffer.
 */
int ler_inteiro(const char *prompt) {
    printf("  %s", prompt);
    int val = 0;
    if (scanf("%d", &val) != 1) val = -1;
    int c;
    while ((c = getchar()) != '\n' && c != EOF); /* esvazia buffer */
    return val;
}

/* ================================================================
   SEÇÃO 7 — VALIDAÇÃO DE DADOS
   ================================================================ */

/*
 * Verifica se o CPF tem exatamente 11 dígitos numéricos.
 * Aceita formatos com ou sem pontuação: 00000000000 ou 000.000.000-00
 * Retorna 1 se válido, 0 se inválido.
 */
int cpf_valido(const char *cpf) {
    int digitos = 0;
    for (int i = 0; cpf[i]; i++) {
        if (isdigit((unsigned char)cpf[i]))
            digitos++;
        else if (cpf[i] != '.' && cpf[i] != '-')
            return 0; /* caractere inválido */
    }
    return (digitos == 11);
}

/*
 * Converte qualquer formato de CPF para o padrão 000.000.000-00.
 * Opera in-place na string recebida.
 */
void formatar_cpf(char *cpf) {
    char d[12] = {0};
    int j = 0;
    for (int i = 0; cpf[i] && j < 11; i++)
        if (isdigit((unsigned char)cpf[i]))
            d[j++] = cpf[i];
    if (j == 11)
        snprintf(cpf, TAM_CPF, "%c%c%c.%c%c%c.%c%c%c-%c%c",
            d[0],d[1],d[2], d[3],d[4],d[5], d[6],d[7],d[8], d[9],d[10]);
}

/*
 * Verifica se o CPF já existe no banco de dados informado.
 * Retorna 1 se duplicado, 0 se disponível.
 */
int cpf_duplicado(const BancoDados *bd, const char *cpf) {
    for (int i = 0; i < bd->total; i++)
        if (strcmp(bd->registros[i].cpf, cpf) == 0)
            return 1;
    return 0;
}

