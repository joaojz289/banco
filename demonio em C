/*
 * Lê o arquivo CSV de uma categoria e preenche o array de registros
 * em memória. Também calcula o próximo ID disponível.
 *
 * O delimitador '|' foi escolhido por ser raro em nomes e textos comuns,
 * evitando conflitos com vírgulas presentes em campos de texto livre.
 *
 * Retorna 1 se o arquivo existia, 0 caso contrário (primeira execução).
 */

/*
 * Gera registros automáticos para popular o banco na primeira execução.
 * Cada categoria recebe 20 registros fictícios.
 */
void gerar_registros_fantasmas(BancoDados *bd, int categoria) {
    const char *nomes[] = {
        "Lucas Silva", "Mariana Costa", "Pedro Henrique", "Ana Beatriz",
        "Carlos Eduardo", "Fernanda Lima", "Rafael Souza", "Julia Martins",
        "Bruno Oliveira", "Camila Rocha", "Gabriel Alves", "Larissa Gomes",
        "Thiago Pereira", "Amanda Ribeiro", "Matheus Fernandes", "Bianca Melo",
        "Joao Victor", "Patricia Santos", "Gustavo Almeida", "Leticia Araujo"
    };

    for (int i = 0; i < 20; i++) {
        Registro *r = &bd->registros[bd->total];

        r->id = bd->proximo_id++;
        snprintf(r->nome, TAM_NOME, "%s", nomes[i]);

        snprintf(r->cpf, TAM_CPF, "%03d.%03d.%03d-%02d",
                 100 + i, 200 + i, 300 + i, 10 + i);

        snprintf(r->telefone, TAM_TEL, "(86) 9%04d-%04d",
                 1000 + i, 2000 + i);

        snprintf(r->email, TAM_EMAIL,
                 "usuario%d@sgbdlite.com", i + 1);

        obter_data(r->data_cadastro, TAM_DATA);

        strcpy(r->observacoes, "Registro fantasma gerado automaticamente.");

        switch (categoria) {
            case 0:
                snprintf(r->campo1, TAM_CAMPO, "Turma %dA", i + 1);
                snprintf(r->campo2, TAM_CAMPO, "Manha");
                snprintf(r->campo3, TAM_CAMPO, "%d Ano", (i % 3) + 1);
                break;

            case 1:
                snprintf(r->campo1, TAM_CAMPO, "Quarto %d", 100 + i);
                snprintf(r->campo2, TAM_CAMPO, "Setor %d", (i % 5) + 1);
                snprintf(r->campo3, TAM_CAMPO, "Convenio Premium");
                break;

            case 2:
                snprintf(r->campo1, TAM_CAMPO, "Funcionario");
                snprintf(r->campo2, TAM_CAMPO, "TI");
                snprintf(r->campo3, TAM_CAMPO, "MAT-%04d", i + 1);
                break;

            case 3:
                snprintf(r->campo1, TAM_CAMPO, "Clinico Geral");
                snprintf(r->campo2, TAM_CAMPO, "Dr. Roberto");
                snprintf(r->campo3, TAM_CAMPO, "Convenio Plus");
