/*
 * Pausa o programa até o usuário pressionar ENTER.
 * Consome qualquer caractere residual no buffer de entrada.
 */
void pausar(void) {
    printf("\n" C_AMAR "  Pressione ENTER para continuar..." C_RESET);
    int c;
    while ((c = getchar()) != '\n' && c != EOF);
}

/* Imprime uma linha separadora com o caractere 'c' repetido 'tam' vezes */
void linha(char c, int tam) {
    printf("  ");
    for (int i = 0; i < tam; i++) putchar(c);
    putchar('\n');
}

/* Limpa a tela e exibe o cabeçalho padrão do sistema */
