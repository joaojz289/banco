

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

/* ======================== STRUCTS ======================== */

typedef struct {
    char nome[80];
    char cpf[15];
    char telefone[16];
    char matricula[20];
    char curso[50];
} Aluno;

typedef struct {
    char nome[80];
    char cpf[15];
    char telefone[16];
    char cartao_sus[20];
    char convenio[50];
} Paciente;

typedef struct {
    char nome[80];
    char cpf[15];
    char telefone[16];
    char num_conta[20];
    char tipo_conta[30]; /* Corrente, Poupanca, Salario */
} Cliente;

typedef struct {
    char nome[80];
    char cpf[15];
    char telefone[16];
    char num_reserva[20];
    char tipo_quarto[30]; /* Single, Double, Suite */
} Hospede;

/* ======================== UTILITARIOS ======================== */

void limpar_tela() {
#ifdef _WIN32
    system("cls");
#else
    system("clear");
#endif
}

void pausar() {
    printf("\n  Pressione ENTER para continuar...");
    getchar();
    getchar();
}

void linha(int n) {
    for (int i = 0; i < n; i++) printf("=");
    printf("\n");
}

/* ======================== ESCOLA ======================== */

#define ARQ_ESCOLA "escola.dat"

void escola_cadastrar() {
    Aluno a;
    printf("\n  [ESCOLA] Novo Aluno\n");
    linha(40);
    printf("  Nome      : "); scanf(" %79[^\n]", a.nome);
    printf("  CPF       : "); scanf(" %14[^\n]", a.cpf);
    printf("  Telefone  : "); scanf(" %15[^\n]", a.telefone);
    printf("  Matricula : "); scanf(" %19[^\n]", a.matricula);
    printf("  Curso     : "); scanf(" %49[^\n]", a.curso);

    FILE *f = fopen(ARQ_ESCOLA, "ab");
    if (!f) { printf("  ERRO ao abrir arquivo!\n"); return; }
    fwrite(&a, sizeof(Aluno), 1, f);
    fclose(f);
    printf("\n  Aluno cadastrado com sucesso!\n");
}

void escola_listar() {
    Aluno a;
    FILE *f = fopen(ARQ_ESCOLA, "rb");
    printf("\n  [ESCOLA] Lista de Alunos\n");
    linha(60);
    if (!f) { printf("  Nenhum registro encontrado.\n"); return; }
    int count = 0;
    while (fread(&a, sizeof(Aluno), 1, f)) {
        count++;
        printf("  #%d\n", count);
        printf("  Nome      : %s\n", a.nome);
        printf("  CPF       : %s\n", a.cpf);
        printf("  Telefone  : %s\n", a.telefone);
        printf("  Matricula : %s\n", a.matricula);
        printf("  Curso     : %s\n", a.curso);
        linha(60);
    }
    fclose(f);
    if (count == 0) printf("  Nenhum registro encontrado.\n");
    else printf("  Total: %d aluno(s)\n", count);
}

void escola_buscar() {
    Aluno a;
    char cpf[15];
    printf("\n  Buscar por CPF: "); scanf(" %14[^\n]", cpf);
    FILE *f = fopen(ARQ_ESCOLA, "rb");
    if (!f) { printf("  Nenhum registro encontrado.\n"); return; }
    int achou = 0;
    while (fread(&a, sizeof(Aluno), 1, f)) {
        if (strcmp(a.cpf, cpf) == 0) {
            printf("\n  Encontrado:\n");
            printf("  Nome      : %s\n", a.nome);
            printf("  CPF       : %s\n", a.cpf);
            printf("  Telefone  : %s\n", a.telefone);
            printf("  Matricula : %s\n", a.matricula);
            printf("  Curso     : %s\n", a.curso);
            achou = 1;
        }
    }
    fclose(f);
    if (!achou) printf("  CPF nao encontrado.\n");
}

void menu_escola() {
    int op;
    do {
        limpar_tela();
        linha(40);
        printf("    ESCOLA\n");
        linha(40);
        printf("  1. Cadastrar Aluno\n");
        printf("  2. Listar Alunos\n");
        printf("  3. Buscar por CPF\n");
        printf("  0. Voltar\n");
        linha(40);
        printf("  Opcao: "); scanf("%d", &op);
        switch (op) {
            case 1: escola_cadastrar(); pausar(); break;
            case 2: escola_listar();    pausar(); break;
            case 3: escola_buscar();    pausar(); break;
        }
    } while (op != 0);
}

