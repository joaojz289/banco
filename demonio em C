/*
 * Funções de comparação para qsort().
 * cmp_nome → ordena alfabeticamente pelo nome
 * cmp_id   → ordena numericamente pelo ID
 */
int cmp_nome(const void *a, const void *b) {
    return strcmp(((const Registro *)a)->nome,
                  ((const Registro *)b)->nome);
}

int cmp_id(const void *a, const void *b) {
    return ((const Registro *)a)->id - ((const Registro *)b)->id;
}

