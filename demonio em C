/*
 * Registro — representa um cadastro completo de uma pessoa.
 *
 * Campos fixos:
 *   id            → identificador único, gerado automaticamente
 *   nome          → nome completo
 *   cpf           → CPF formatado (000.000.000-00)
 *   telefone      → contato telefônico
 *   email         → endereço de e-mail
 *   data_cadastro → data/hora automática ao inserir
 *   observacoes   → notas livres
 *
 * Campos genéricos (campo1/campo2/campo3):
 *   Recebem rótulos específicos por categoria:
 *   Escola   → Turma   | Período | Série
 *   Hospital → Quarto  | Setor   | Convênio
 *   Empresa  → Cargo   | Depart. | Matrícula
 *   Clínica  → Espec.  | Médico  | Convênio
 */
typedef struct {
    int  id;
    char nome[TAM_NOME];
    char cpf[TAM_CPF];
    char telefone[TAM_TEL];
    char email[TAM_EMAIL];
    char campo1[TAM_CAMPO];
    char campo2[TAM_CAMPO];
    char campo3[TAM_CAMPO];
    char data_cadastro[TAM_DATA];
    char observacoes[TAM_OBS];
} Registro;

/*
 * BancoDados — armazena todos os registros de UMA categoria.
 *
 *   registros[]  → array estático de registros em memória
 *   total        → quantidade de registros atualmente carregados
 *   proximo_id   → próximo ID a ser atribuído (auto-incremento)
 *   nome         → nome legível da categoria (ex: "Escola")
 *   arquivo      → caminho do arquivo CSV desta categoria
 *   label1/2/3   → rótulos dos campos genéricos
 *   icone        → prefixo visual usado nos menus
 */
typedef struct {
    Registro registros[MAX_REGISTROS];
    int      total;
    int      proximo_id;
    char     nome[30];
    char     arquivo[150];
    char     label1[30];
    char     label2[30];
    char     label3[30];
    char     icone[10];
} BancoDados;

